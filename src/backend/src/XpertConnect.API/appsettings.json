{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=xpertconnect;Username=postgres;Password=your_password_here"
  },
  "JwtSettings": {
    "Secret": "REPLACE_WITH_A_SECURE_SECRET_KEY_AT_LEAST_32_CHARACTERS",
    "Issuer": "XpertConnect",
    "Audience": "XpertConnectUsers",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  }
}
